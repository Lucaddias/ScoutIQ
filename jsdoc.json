{
  "plugins": [
    "plugins/markdown"
  ],
  "source": {
    "include": [
      "src"
    ],
    "includePattern": ".+\\.js(doc|x)?$",
    "excludePattern": "(^|\\/|\\\\)_"
  },
  "opts": {
    "template": "node_modules/docdash",
    "destination": "./docs/",
    "recurse": true,
    "readme": "README.md"
  },
  "docdash": {
    "collapse": true,
    "wrap": true,
    "typedefs": true,
    "private": false,
    "removeSource": false,
    "search": true,
    "commonNav": false
  },
  "templates": {
    "cleverLinks": false,
    "monospaceLinks": false
  }
}